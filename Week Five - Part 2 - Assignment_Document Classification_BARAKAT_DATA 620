    "def get_feature_importance(model_name, fitted_model, feature_names):\n",
    "    if model_name == \"Random Forest\" or model_name == \"Decision Tree\":\n",
    "        values = fitted_model.feature_importances_\n",
    "        label = \"Feature Importance\"\n",
    "\n",
    "    elif model_name == \"Logistic Regression\":\n",
    "        values = fitted_model.named_steps[\"model\"].coef_[0]\n",
    "        label = \"Standardized Coefficient\"\n",
    "\n",
    "    else:\n",
    "        rf_explainer = fitted_models[\"Random Forest\"]\n",
    "        values = rf_explainer.feature_importances_\n",
    "        label = \"Random Forest Feature Importance\"\n",
    "\n",
    "    importance_df = pd.DataFrame({\n",
    "        \"Feature\": feature_names,\n",
    "        label: values\n",
    "    })\n",
    "\n",
    "    importance_df[\"Absolute Importance\"] = np.abs(importance_df[label])\n",
    "\n",
    "    return (\n",
